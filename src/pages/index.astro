---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVisual from "../components/HeroVisual";
import { cases, metrics, profile } from "../data/site";
---

<BaseLayout>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="role">{profile.role}</p>
      <h1>{profile.name}</h1>
      <p class="hero-line">{profile.headline}</p>
      <div class="focus-row" aria-label="Focus areas">
        {profile.focus.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <HeroVisual client:load />
  </section>

  <section class="metric-band" aria-label="Selected metrics">
    {metrics.map((metric) => (
      <article>
        <strong>{metric.value}</strong>
        <h2>{metric.label}</h2>
        <p>{metric.detail}</p>
      </article>
    ))}
  </section>

  <section class="systems-section" id="selected-systems">
    <div class="section-heading">
      <p>Selected Systems</p>
      <h2>Three systems that show how ambiguous workflows become reliable AI products.</h2>
    </div>
    <div class="systems-grid">
      {cases.map((item) => (
        <a class="system-card" href={item.href}>
          <span class="case-number">Case Study {item.number}</span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <div class="tag-row">
            {item.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
          </div>
          <strong>{item.outcome}</strong>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
