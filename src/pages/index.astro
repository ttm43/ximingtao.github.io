---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductLaunchHero from "../components/ProductLaunchHero";
import ProductLineCards from "../components/ProductLineCards";
import { cases, intro, metrics, products, profile } from "../data/site";
import { sitePath } from "../utils/paths";

const productLinks = products.map((product) => ({
  ...product,
  href: sitePath(product.href),
}));
---

<BaseLayout>
  <section class="hero-section launch-section">
    <div class="hero-copy">
      <p class="role">{profile.name} / {profile.role}</p>
      <h1>{profile.headline}</h1>
      <p class="hero-line">{profile.launchSubheadline}</p>
      <div class="focus-row" aria-label="Focus areas">
        {profile.focus.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <ProductLaunchHero client:load />
  </section>

  <section class="product-lines-section" id="product-lines">
    <div class="section-heading">
      <p>Product Lines</p>
      <h2>Four systems, one pattern: probabilistic AI understanding connected to controlled business execution.</h2>
    </div>
    <ProductLineCards products={productLinks} client:load />
  </section>

  <section class="intro-section">
    <div class="section-heading">
      <p>Introduction</p>
      <h2>{intro.title}</h2>
    </div>
    <div class="intro-grid">
      <p>{intro.body}</p>
      <ol>
        {intro.timeline.map((item) => <li>{item}</li>)}
      </ol>
    </div>
  </section>

  <section class="metric-band" aria-label="Selected metrics">
    {metrics.map((metric) => (
      <article>
        <strong>{metric.value}</strong>
        <h2>{metric.label}</h2>
        <p>{metric.detail}</p>
      </article>
    ))}
  </section>

  <section class="systems-section" id="selected-systems">
    <div class="section-heading">
      <p>Deep Dives</p>
      <h2>Three product case studies for the interview walkthrough.</h2>
    </div>
    <div class="systems-grid">
      {cases.map((item) => (
        <a class="system-card" href={sitePath(item.href)}>
          <span class="case-number">Product {item.number}</span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <div class="tag-row">
            {item.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
          </div>
          <strong>{item.outcome}</strong>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
