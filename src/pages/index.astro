---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroWorkflowPlayback from "../components/HeroWorkflowPlayback";
import MetricsExplorer from "../components/MetricsExplorer";
import SystemCardsInteractive from "../components/SystemCardsInteractive";
import { cases, intro, metrics, profile } from "../data/site";
import { sitePath } from "../utils/paths";
---

<BaseLayout>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="role">{profile.role}</p>
      <h1>{profile.name}</h1>
      <p class="hero-line">{profile.headline}</p>
      <div class="focus-row" aria-label="Focus areas">
        {profile.focus.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <HeroWorkflowPlayback client:load />
  </section>

  <section class="intro-section">
    <div class="section-heading">
      <p>Introduction</p>
      <h2>{intro.title}</h2>
    </div>
    <div class="intro-grid">
      <p>{intro.body}</p>
      <ol>
        {intro.timeline.map((item) => <li>{item}</li>)}
      </ol>
    </div>
  </section>

  <MetricsExplorer metrics={metrics} client:load />

  <section class="systems-section" id="selected-systems">
    <div class="section-heading">
      <p>Selected Systems</p>
      <h2>Three systems that show how ambiguous workflows become reliable AI products.</h2>
    </div>
    <SystemCardsInteractive cases={cases} baseUrl={sitePath()} client:load />
  </section>
</BaseLayout>
