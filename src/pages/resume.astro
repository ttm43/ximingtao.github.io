---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile, resume } from "../data/site";
import { sitePath } from "../utils/paths";
---

<BaseLayout title={`Resume - ${profile.name}`}>
  <section class="resume-hero">
    <div>
      <p>{profile.role}</p>
      <h1>{profile.name}</h1>
      <span>{profile.headline}</span>
    </div>
    <a class="print-button" href={sitePath(profile.links.resumePdf)} download>Download PDF</a>
  </section>

  <section class="resume-section summary-section">
    <h2>Summary</h2>
    <p>{resume.summary}</p>
  </section>

  <section class="resume-section">
    <h2>Experience</h2>
    <div class="resume-list">
      {resume.experience.map((item) => (
        <article>
          <div>
            <h3>{item.title}</h3>
            <span>{item.meta}</span>
          </div>
          <ul>
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="resume-section">
    <h2>Skills</h2>
    <div class="skill-groups">
      {resume.skillGroups.map((group) => (
        <article>
          <h3>{group.title}</h3>
          <div class="skill-list">
            {group.items.map((skill) => <span>{skill}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="resume-section">
    <h2>Education</h2>
    <div class="resume-list">
      {resume.education.map((item) => (
        <article>
          <div>
            <h3>{item.degree}</h3>
            <span>{item.school}</span>
          </div>
          <p>{item.years}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="resume-section">
    <h2>Other</h2>
    <div class="skill-list">
      {resume.licenses.map((item) => <span>{item}</span>)}
    </div>
  </section>
</BaseLayout>
