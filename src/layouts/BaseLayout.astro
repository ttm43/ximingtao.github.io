---
import "../styles/global.css";
import { profile } from "../data/site";
import { sitePath } from "../utils/paths";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} - ${profile.role}`,
  description = profile.headline,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <link rel="icon" href={sitePath("favicon.ico")} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={sitePath()} class="brand" aria-label="Ximing Tao home">
        <span class="brand-mark">XT</span>
        <span>{profile.name}</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={sitePath("#product-lines")}>Product Lines</a>
        <a href={sitePath("case-studies/order-processing/")}>OrderOps AI</a>
        <a href={sitePath("case-studies/controlled-knowledge-system/")}>KnowledgeGuard</a>
        <a href={sitePath("case-studies/document-intelligence/")}>DocParse</a>
        <a href={sitePath("resume/")}>Resume</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>{profile.name}</span>
      <span>AI Engineer</span>
      <a href={profile.links.github}>GitHub</a>
    </footer>
  </body>
</html>
